{
  "manifest_version": 3,
  "name": "ghksjk",
  "version": "1.5.0",
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://raw.githubusercontent.com/yuanchenxi95/tabcloser/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
